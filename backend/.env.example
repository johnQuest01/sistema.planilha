# Copie para backend/.env e preencha. NUNCA commite o .env real.

# Neon (Postgres) — formato: postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=

# HTTP
PORT=3333
CORS_ORIGIN=http://localhost:5173

# Assina o cookie de sessão do dono.
# Dev pode usar este. Em produção é OBRIGATÓRIO e o processo não sobe sem ele.
# Gere o de produção com: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
COOKIE_SECRET=dev-local-somente-nao-use-em-producao

# --- Cloudflare R2 (só na Fase 5, deixe em branco por enquanto) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE=
