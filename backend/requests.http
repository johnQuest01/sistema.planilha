@host = http://localhost:3333

### Registrar dono (guarda o cookie de sessão automaticamente)
# @name registrar
POST {{host}}/api/auth/registrar
Content-Type: application/json

{ "email": "dono@exemplo.com", "senha": "segredo123" }

### Entrar (caso já tenha registrado antes)
# @name entrar
POST {{host}}/api/auth/entrar
Content-Type: application/json

{ "email": "dono@exemplo.com", "senha": "segredo123" }

### Quem sou eu
GET {{host}}/api/auth/eu

### Criar planilha
# @name criarColecao
POST {{host}}/api/colecoes
Content-Type: application/json

{ "nome": "Doces" }

### Listar planilhas
GET {{host}}/api/colecoes

### Guardar o id da planilha criada
@colecaoId = {{criarColecao.response.body.id}}

### Campo texto
POST {{host}}/api/colecoes/{{colecaoId}}/campos
Content-Type: application/json

{ "nome": "Sabor", "tipo": "texto" }

### Campo numero com sufixo
POST {{host}}/api/colecoes/{{colecaoId}}/campos
Content-Type: application/json

{ "nome": "Peso", "tipo": "numero", "config": { "sufixo": "g" } }

### Campo data
POST {{host}}/api/colecoes/{{colecaoId}}/campos
Content-Type: application/json

{ "nome": "Validade", "tipo": "data" }

### Campo booleano
POST {{host}}/api/colecoes/{{colecaoId}}/campos
Content-Type: application/json

{ "nome": "Tem lactose", "tipo": "booleano" }

### Campo selecao (guardando id pra mover/editar/apagar)
# @name campoStatus
POST {{host}}/api/colecoes/{{colecaoId}}/campos
Content-Type: application/json

{ "nome": "Status", "tipo": "selecao", "config": { "opcoes": ["Pronto", "Produzindo"] } }

### Campo imagem
POST {{host}}/api/colecoes/{{colecaoId}}/campos
Content-Type: application/json

{ "nome": "Foto", "tipo": "imagem" }

@campoStatusId = {{campoStatus.response.body.id}}

### Selecao sem opcoes deve dar 400
POST {{host}}/api/colecoes/{{colecaoId}}/campos
Content-Type: application/json

{ "nome": "Quebrado", "tipo": "selecao" }

### Chave desconhecida deve dar 400 (.strict)
POST {{host}}/api/colecoes/{{colecaoId}}/campos
Content-Type: application/json

{ "nome": "X", "tipo": "texto", "lixo": "nao_deveria_passar" }

### Ver planilha com os campos na ordem
GET {{host}}/api/colecoes/{{colecaoId}}

### Reordenar os campos em lote (ordem final completa)
PATCH {{host}}/api/colecoes/{{colecaoId}}/campos/ordem
Content-Type: application/json

{ "ids": ["{{campoStatusId}}"] }

### Duplicar a planilha (formato em branco: sem registros, sem convites, ids novos)
POST {{host}}/api/colecoes/{{colecaoId}}/duplicar

### Editar o campo Status (adiciona opção)
PATCH {{host}}/api/campos/{{campoStatusId}}
Content-Type: application/json

{ "config": { "opcoes": ["Pronto", "Produzindo", "Esgotado"] } }

### Renomear planilha
PATCH {{host}}/api/colecoes/{{colecaoId}}
Content-Type: application/json

{ "nome": "Doces da casa" }

### Apagar o campo Status (remove a chave dos valores dos registros)
DELETE {{host}}/api/campos/{{campoStatusId}}

### Ver de novo (ordem preservada, sem o Status)
GET {{host}}/api/colecoes/{{colecaoId}}

### ======================= Fase 3: registros =======================

### Campo imagem maxFotos 1 (capa única)
# @name campoFoto1
POST {{host}}/api/colecoes/{{colecaoId}}/campos
Content-Type: application/json

{ "nome": "Capa", "tipo": "imagem", "config": { "maxFotos": 1 } }

@campoFoto1Id = {{campoFoto1.response.body.id}}

### Campo imagem maxFotos 5 (galeria)
# @name campoFoto5
POST {{host}}/api/colecoes/{{colecaoId}}/campos
Content-Type: application/json

{ "nome": "Galeria", "tipo": "imagem", "config": { "maxFotos": 5 } }

@campoFoto5Id = {{campoFoto5.response.body.id}}

### Campo numero (guardar id pro registro e pro teste de 409)
# @name campoPeso
POST {{host}}/api/colecoes/{{colecaoId}}/campos
Content-Type: application/json

{ "nome": "Gramatura", "tipo": "numero", "config": { "sufixo": "g/m2" } }

@campoPesoId = {{campoPeso.response.body.id}}

### maxFotos em bloco que NÃO é imagem deve dar 400 (seção 4.2)
POST {{host}}/api/colecoes/{{colecaoId}}/campos
Content-Type: application/json

{ "nome": "Errado", "tipo": "texto", "config": { "maxFotos": 3 } }

### Criar registro com número + galeria vazia → 201
# @name registro1
POST {{host}}/api/colecoes/{{colecaoId}}/registros
Content-Type: application/json

{ "valores": { "{{campoPesoId}}": 180, "{{campoFoto5Id}}": [] } }

@registroId = {{registro1.response.body.id}}

### Chave inventada nos valores → 400 (.strict)
POST {{host}}/api/colecoes/{{colecaoId}}/registros
Content-Type: application/json

{ "valores": { "chave_inventada": "x" } }

### imagem como string solta (não array) → 400
POST {{host}}/api/colecoes/{{colecaoId}}/registros
Content-Type: application/json

{ "valores": { "{{campoFoto1Id}}": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa/bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb/aaaaaaaaaaaaaaaaaaaaa.jpg" } }

### imagem com URL em vez de key → 400
POST {{host}}/api/colecoes/{{colecaoId}}/registros
Content-Type: application/json

{ "valores": { "{{campoFoto1Id}}": ["https://evil.com/a.jpg"] } }

### 3 keys num campo maxFotos 1 → 400
POST {{host}}/api/colecoes/{{colecaoId}}/registros
Content-Type: application/json

{ "valores": { "{{campoFoto1Id}}": [
  "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa/bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb/aaaaaaaaaaaaaaaaaaaaa.jpg",
  "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa/bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb/bbbbbbbbbbbbbbbbbbbbb.jpg",
  "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa/bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb/ccccccccccccccccccccc.jpg"
] } }

### 3 keys num campo maxFotos 5 → 201
POST {{host}}/api/colecoes/{{colecaoId}}/registros
Content-Type: application/json

{ "valores": { "{{campoFoto5Id}}": [
  "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa/bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb/aaaaaaaaaaaaaaaaaaaaa.jpg",
  "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa/bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb/bbbbbbbbbbbbbbbbbbbbb.jpg",
  "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa/bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb/ccccccccccccccccccccc.jpg"
] } }

### numero como string → 400
POST {{host}}/api/colecoes/{{colecaoId}}/registros
Content-Type: application/json

{ "valores": { "{{campoPesoId}}": "180" } }

### PATCH de um campo só preserva os outros (merge)
PATCH {{host}}/api/registros/{{registroId}}
Content-Type: application/json

{ "valores": { "{{campoPesoId}}": 200 } }

### Listar registros da coleção
GET {{host}}/api/colecoes/{{colecaoId}}/registros

### Presign de upload — 2 derivadas (cheia + mini). Precisa R2 configurado; senão 503.
# @name presign
POST {{host}}/api/registros/{{registroId}}/upload
Content-Type: application/json

{ "mime": "image/jpeg", "tamanhoCheia": 900000, "tamanhoMini": 45000 }

### Upload com arquivo > 2 MB → 400 (seção 6.5)
POST {{host}}/api/registros/{{registroId}}/upload
Content-Type: application/json

{ "mime": "image/jpeg", "tamanhoCheia": 3000000, "tamanhoMini": 45000 }

### Upload com mime não suportado → 400
POST {{host}}/api/registros/{{registroId}}/upload
Content-Type: application/json

{ "mime": "image/gif", "tamanhoCheia": 100000, "tamanhoMini": 20000 }

### Trocar o tipo de um campo com registros existentes → 409 (2.5.6)
PATCH {{host}}/api/campos/{{campoPesoId}}
Content-Type: application/json

{ "tipo": "texto" }

### :id não-uuid vira 404, não 500 (2.5.5)
GET {{host}}/api/colecoes/nao-e-uuid/registros

### Registro de outra conta / inexistente → 404 (RLS)
PATCH {{host}}/api/registros/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{ "valores": {} }

### Apagar registro → 204
DELETE {{host}}/api/registros/{{registroId}}

### Sair (revoga a sessão no servidor, não só limpa o cookie — 2.5.3)
POST {{host}}/api/auth/sair

### Sem sessão, criar campo deve dar 401
POST {{host}}/api/colecoes/{{colecaoId}}/campos
Content-Type: application/json

{ "nome": "NaoDeveria", "tipo": "texto" }

### Rate limit: reenviar este POST 11x em 1 min → o 11º responde 429 (2.5.4)
POST {{host}}/api/auth/entrar
Content-Type: application/json

{ "email": "dono@exemplo.com", "senha": "errada" }
